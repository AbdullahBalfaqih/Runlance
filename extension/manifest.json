{
  "manifest_version": 3,
  "name": "Runlance - Job Analysis Assistant",
  "version": "1.0.0",
  "description": "Analyze job postings in real-time and get AI-powered insights to improve your chances",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest",
    "alarms",
    "contextMenus",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Career AI"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "content.js"],
      "run_at": "document_end"
    }
  ]
}